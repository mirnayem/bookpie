{
  "name": "bookpie-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "api:dev": "cargo run -p api",
    "api:check": "cargo check -p api",
    "api:clippy": "cargo clippy -p api --all-targets --all-features",
    "web:dev": "npm run dev --workspace @bookpie/web",
    "web:build": "npm run build --workspace @bookpie/web",
    "web:lint": "npm run lint --workspace @bookpie/web",
    "web:typecheck": "npm run typecheck --workspace @bookpie/web"
  }
}
