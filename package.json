{
  "name": "bookpie-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "api:dev": "cargo run -p api",
    "api:check": "cargo check -p api",
    "api:clippy": "cargo clippy -p api --all-targets --all-features",
    "web:dev": "pnpm --filter @bookpie/web dev",
    "web:build": "pnpm --filter @bookpie/web build",
    "web:lint": "pnpm --filter @bookpie/web lint",
    "web:typecheck": "pnpm --filter @bookpie/web typecheck"
  }
}
